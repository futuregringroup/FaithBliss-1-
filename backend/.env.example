# Copy this file to .env for local development.
# NEVER commit .env to version control.
# In production (Vercel), set these as environment variables in the dashboard.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────────────────
# Frontend URL allowed by CORS (no trailing slash)
CLIENT_URL=http://localhost:5173

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/faithbliss

# ── Firebase Admin SDK ──────────────────────────────────────────────────────
# Base64-encoded Firebase service account JSON.
# Generate on Linux/macOS: base64 -i serviceAccountKey.json | tr -d '\n'
# Generate on Windows:     [Convert]::ToBase64String([IO.File]::ReadAllBytes('serviceAccountKey.json'))
FIREBASE_CREDENTIALS_BASE64=

# ── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PLAN_CODE_PREMIUM_MONTHLY=
PAYSTACK_PLAN_CODE_PREMIUM_QUARTERLY=

# ── Google OAuth (Passport.js) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Email Notifications ──────────────────────────────────────────────────────
# Webhook URL for outbound email notifications (optional)
EMAIL_WEBHOOK_URL=
