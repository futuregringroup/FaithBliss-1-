{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-stories",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/renew-subscriptions",
      "schedule": "*/15 * * * *"
    }
  ]
}
