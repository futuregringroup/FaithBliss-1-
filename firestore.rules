rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getMatch(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    function matchExists(matchId) {
      return exists(/databases/$(database)/documents/matches/$(matchId));
    }

    // users — only the document owner may read their own profile via the client
    // SDK (syncUserFromFirebase, fetchUserDataFromFirestore). All other profile
    // reads (e.g. UserProfileView) go through the backend API which filters out
    // PII before responding. The backend uses the Admin SDK which bypasses rules.
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // matches — only participants (users[] array members) can read or update.
    // Creation and deletion are done exclusively by the backend via Admin SDK.
    match /matches/{matchId} {
      allow read:   if isSignedIn() && request.auth.uid in resource.data.users;
      allow update: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if false;
      allow delete: if false;
    }

    // messages — only the sender or receiver can read/update.
    // Creation requires: caller is the sender, the referenced match exists,
    // and caller is a participant in that match.
    match /messages/{messageId} {
      allow read:   if isSignedIn() &&
                       (request.auth.uid == resource.data.senderId ||
                        request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() &&
                       request.auth.uid == request.resource.data.senderId &&
                       matchExists(request.resource.data.matchId) &&
                       request.auth.uid in getMatch(request.resource.data.matchId).users;
      allow update: if isSignedIn() &&
                       (request.auth.uid == resource.data.senderId ||
                        request.auth.uid == resource.data.receiverId);
      allow delete: if false;
    }

    // notifications — recipient only.
    // Client may only toggle the isRead field; all other writes are backend-only.
    match /notifications/{notificationId} {
      allow read:   if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['isRead']);
      allow create: if false;
      allow delete: if false;
    }

    // stories — all signed-in users can read.
    // Only the author can create or delete their story.
    // Any signed-in user may mark a story as seen or liked (seenBy/likedBy only).
    match /stories/{storyId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() &&
                       request.auth.uid == request.resource.data.authorId;
      allow update: if isSignedIn() &&
                       (request.auth.uid == resource.data.authorId ||
                        request.resource.data.diff(resource.data)
                          .affectedKeys().hasOnly(['seenBy', 'likedBy']));
      allow delete: if isOwner(resource.data.authorId);
    }

    // supportTickets — owner can read their own tickets and create new ones.
    // Admin replies are written exclusively by the backend via Admin SDK.
    match /supportTickets/{ticketId} {
      allow read:   if isOwner(resource.data.userId);
      allow create: if isSignedIn() &&
                       request.auth.uid == request.resource.data.userId;
      allow update: if false;
      allow delete: if false;
    }

    // ─── chats (Firestore-native real-time messaging) ───────────────────────
    //
    // The parent document at chats/{matchId} declares the two participants.
    // Two schema variations are supported — use whichever matches your data:
    //
    //   Variation A — userIds array:   { userIds: [uid1, uid2] }
    //   Variation B — discrete fields: { user1Id: uid1, user2Id: uid2 }
    //
    // Only the participant check helper needs to change; all other rules are
    // identical between the two variations.

    // ── Variation A: userIds[] array ──────────────────────────────────────
    match /chats/{matchId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.userIds;
      allow create, update, delete: if false; // backend-only via Admin SDK
    }

    match /chats/{matchId}/messages/{messageId} {
      // Read: caller must be a participant in the parent chat document.
      allow read: if isSignedIn() &&
                     request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(matchId)).data.userIds;

      // Create: caller is the sender and is a participant in the parent doc.
      // No client may backdate or forge the timestamp — only serverTimestamp()
      // is accepted (the field must be missing from the incoming write so the
      // server fills it in via FieldValue.serverTimestamp).
      allow create: if isSignedIn() &&
                       request.auth.uid == request.resource.data.senderId &&
                       request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(matchId)).data.userIds &&
                       !('timestamp' in request.resource.data);

      // Updates (e.g. marking isRead) are only allowed for the recipient.
      allow update: if isSignedIn() &&
                       request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(matchId)).data.userIds &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['isRead']);

      allow delete: if false;
    }

    // ── Variation B: user1Id / user2Id discrete fields ────────────────────
    // Uncomment this block (and remove Variation A above) if your chats
    // documents use { user1Id: "...", user2Id: "..." } instead of userIds[].
    //
    // function isChatParticipant(matchId) {
    //   let chat = get(/databases/$(database)/documents/chats/$(matchId)).data;
    //   return request.auth.uid == chat.user1Id || request.auth.uid == chat.user2Id;
    // }
    //
    // match /chats/{matchId} {
    //   allow read: if isSignedIn() && isChatParticipant(matchId);
    //   allow create, update, delete: if false;
    // }
    //
    // match /chats/{matchId}/messages/{messageId} {
    //   allow read:   if isSignedIn() && isChatParticipant(matchId);
    //   allow create: if isSignedIn() &&
    //                    request.auth.uid == request.resource.data.senderId &&
    //                    isChatParticipant(matchId) &&
    //                    !('timestamp' in request.resource.data);
    //   allow update: if isSignedIn() &&
    //                    isChatParticipant(matchId) &&
    //                    request.resource.data.diff(resource.data)
    //                      .affectedKeys().hasOnly(['isRead']);
    //   allow delete: if false;
    // }
    // ─────────────────────────────────────────────────────────────────────

    // Deny all other collections not explicitly listed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
