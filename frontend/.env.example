# Copy this file to .env.local for local development.
# NEVER commit .env.local to version control.
# In production (Vercel), set these as environment variables in the dashboard.

# Backend REST API base URL (no trailing slash, no /api suffix)
# Local:      http://localhost:5000
# Production: https://your-backend.vercel.app
VITE_API_URL=http://localhost:5000

# WebSocket server URL (same origin as the backend)
# In production, if the frontend and backend share the same Vercel deployment origin,
# this can be omitted — WebSocketService.ts will auto-detect window.location.origin.
# Set this only if your backend is on a different domain than your frontend.
# Local:      http://localhost:5000
# Production: https://your-backend.vercel.app (or omit entirely)
VITE_WEBSOCKET_URL=http://localhost:5000

# Firebase client-side config (these are public keys — safe to expose in source)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Admin ────────────────────────────────────────────────────────────────────
# Email address of the primary admin account (used to grant admin role on the client)
VITE_PRIMARY_ADMIN_EMAIL=aginaemmanuel6@gmail.com
