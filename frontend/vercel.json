{
  "headers": [
    {
      "source": "/.well-known/apple-developer-merchantid-domain-association",
      "headers": [
        { "key": "Content-Type", "value": "application/text" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com wss://*.firebaseio.com https://api.cloudinary.com https://*.vercel.app https://faithblissafrica.com; img-src 'self' data: blob: https://res.cloudinary.com https://lh3.googleusercontent.com; font-src 'self' data:; frame-src https://faithbliss-79c63.firebaseapp.com; worker-src 'self' blob:; object-src 'none'"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/__/auth/(.*)",
      "dest": "https://faithbliss-79c63.firebaseapp.com/__/auth/$1"
    },
    {
      "src": "/__/firebase/init.json",
      "dest": "https://faithbliss-79c63.firebaseapp.com/__/firebase/init.json"
    },
    {
      "src": "/$",
      "dest": "/index.html"
    },
    {
      "src": "/about/?$",
      "dest": "/about/index.html"
    },
    {
      "src": "/contact/?$",
      "dest": "/contact/index.html"
    },
    {
      "src": "/privacy/?$",
      "dest": "/privacy/index.html"
    },
    {
      "src": "/terms/?$",
      "dest": "/terms/index.html"
    },
    {
      "src": "/help/?$",
      "dest": "/help/index.html"
    },
    {
      "src": "/premium/?$",
      "dest": "/premium/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/app-shell.html"
    }
  ]
}
