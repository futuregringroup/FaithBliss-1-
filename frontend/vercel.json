{
  "routes": [
    {
      "src": "/.well-known/apple-developer-merchantid-domain-association",
      "headers": {
        "Content-Type": "application/text",
        "Cache-Control": "no-cache, no-store, must-revalidate"
      },
      "continue": true
    },
    {
      "src": "/sw\\.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Content-Type": "application/javascript"
      },
      "continue": true
    },
    {
      "src": "/site\\.webmanifest",
      "headers": {
        "Cache-Control": "no-cache",
        "Content-Type": "application/manifest+json"
      },
      "continue": true
    },
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(self)",
        "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com wss://*.firebaseio.com https://api.cloudinary.com https://*.vercel.app https://faithblissafrica.com; img-src 'self' data: blob: https://res.cloudinary.com https://lh3.googleusercontent.com; font-src 'self' data:; frame-src https://faithbliss-79c63.firebaseapp.com; worker-src 'self' blob:; object-src 'none'"
      },
      "continue": true
    },
    {
      "src": "/__/auth/(.*)",
      "dest": "https://faithbliss-79c63.firebaseapp.com/__/auth/$1"
    },
    {
      "src": "/__/firebase/init\\.json",
      "dest": "https://faithbliss-79c63.firebaseapp.com/__/firebase/init.json"
    },
    {
      "src": "/$",
      "dest": "/index.html"
    },
    {
      "src": "/about/?$",
      "dest": "/about/index.html"
    },
    {
      "src": "/contact/?$",
      "dest": "/contact/index.html"
    },
    {
      "src": "/privacy/?$",
      "dest": "/privacy/index.html"
    },
    {
      "src": "/terms/?$",
      "dest": "/terms/index.html"
    },
    {
      "src": "/help/?$",
      "dest": "/help/index.html"
    },
    {
      "src": "/premium/?$",
      "dest": "/premium/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/app-shell.html"
    }
  ]
}
