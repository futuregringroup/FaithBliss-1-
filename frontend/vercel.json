{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/__/auth/(.*)",
      "dest": "https://faithbliss-79c63.firebaseapp.com/__/auth/$1"
    },
    {
      "src": "/__/firebase/init.json",
      "dest": "https://faithbliss-79c63.firebaseapp.com/__/firebase/init.json"
    },
    {
      "src": "/$",
      "dest": "/index.html"
    },
    {
      "src": "/about/?$",
      "dest": "/about/index.html"
    },
    {
      "src": "/contact/?$",
      "dest": "/contact/index.html"
    },
    {
      "src": "/privacy/?$",
      "dest": "/privacy/index.html"
    },
    {
      "src": "/terms/?$",
      "dest": "/terms/index.html"
    },
    {
      "src": "/help/?$",
      "dest": "/help/index.html"
    },
    {
      "src": "/premium/?$",
      "dest": "/premium/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/app-shell.html"
    }
  ]
}
