rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Only authenticated users may upload or read files.
    // Uploads are restricted to image content types and a 5 MB size cap.

    match /profile-photos/{userId}/{allPaths=**} {
      // Owner can read and write their own photos.
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size <= 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp)');
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size <= 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /stories/{userId}/{allPaths=**} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size <= 20 * 1024 * 1024
                    && (request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp)')
                        || request.resource.contentType.matches('video/(mp4|quicktime|webm)'));
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
